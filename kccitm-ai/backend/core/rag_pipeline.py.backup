"""
RAG pipeline for KCCITM AI Assistant — Phase 5 (optimized).

Phase 4 basic pipeline upgraded with 4 optimization layers:
  1. HyDE          — hypothetical answer embedding for better semantic match
  2. Multi-query   — 3 query variants + RRF merge for broader coverage
  3. Re-ranking    — cross-encoder scores 30 candidates → top 10
  4. Compression   — strips irrelevant content from chunks → fewer tokens

The optimized path runs HyDE + multi-query expansion in parallel, then
retrieves for each variant, merges via RRF, re-ranks, compresses, and generates.

Toggle via `use_optimizations` flag (or `settings.RAG_USE_OPTIMIZATIONS`).

Usage:
    pipeline = RAGPipeline(llm, milvus)
    result = await pipeline.run("tell me about Aakash Singh", route_result)
"""

import asyncio
import logging
from dataclasses import dataclass, field

from config import settings
from core.compressor import ContextualCompressor
from core.hyde import HyDEGenerator
from core.llm_client import OllamaClient
from core.multi_query import MultiQueryExpander
from core.reranker import ChunkReranker
from core.router import RouteResult
from db.milvus_client import MilvusSearchClient

logger = logging.getLogger(__name__)

# ── Response generator system prompt ──────────────────────────────────────────

RESPONSE_GENERATOR_PROMPT = """You are KCCITM AI Assistant. You answer questions about student academic data.

ABSOLUTE RULES — BREAK ANY OF THESE AND THE ANSWER IS WRONG:

1. ONLY use data from the context provided below. Do NOT add names, numbers, or subjects that aren't in the context.

2. If the context says subject_code KCS503 has subject_name "Design and Analysis of Algorithm", use THAT name. Never substitute a different subject name.

3. If the context doesn't have enough data to answer, say: "I don't have sufficient data for this query."

4. NEVER mention students or data points that aren't explicitly in the context provided.

FORMAT RULES:

FOR RANKINGS (top N, list):
Always use a markdown table with ALL columns from the data:
| Rank | Name | Roll No | SGPA | Total Marks | Status |
|------|------|---------|------|-------------|--------|
| 1 | STUDENT NAME | 21049201XXXXX | 8.67 | 738 | PASS |

FOR COUNTS:
Give the number first: "There are 487 CSE students."

FOR STUDENT PROFILES:
**STUDENT NAME** (Roll: actual roll number)
Branch: actual branch name

Show ALL semesters in a table:
| Semester | SGPA | Total Marks | Status |
|----------|------|-------------|--------|
| 1 | 8.45 | 719 | PASS |
| 2 | 7.12 | 605 | PASS |
| 3 | 8.41 | 740 | CP(0) |

Best: subject name (Grade, marks)
Needs improvement: subject name (Grade, marks)

Rules for profiles:
- Show EVERY semester the student has data for, not just one
- Never use backticks around values. Write SGPA: 8.45 not SGPA: `8.45`
- Only include lines where you have actual data. Omit any line where you lack the value.

FOR SUBJECT RESULTS:
**SUBJECT NAME** (Code: actual code, Semester number)
| Student Name | Internal | External | Total | Grade |
|-------------|----------|----------|-------|-------|
| NAME 1 | 28 | 65 | 93 | A+ |
| NAME 2 | 22 | 48 | 70 | B+ |
Show ALL students in the results, not just one row. Always show actual numbers.

FOR COMPARISONS:
| Metric | Value 1 | Value 2 | Difference |
|--------|---------|---------|------------|

FORBIDDEN:
- Never start with "I'd be happy to help" or "Based on the provided data"
- Never show SQL queries, JSON, or technical details
- Never wrap values in backticks. Write SGPA: 8.45 and Roll: 2104920100002, NOT SGPA: `8.45` or Roll: `2104920100002`. No backticks anywhere in your response.
- Never invent data — if a student name isn't in the context, don't mention them
- Never mix up subject codes and names
- Never use placeholder values like XX, XXX, XXXXX, or "X.XX". If you don't have the exact value, omit that line entirely.
- Never insert bracket placeholders like [insert X], [not provided], [semester], or [unknown]. If you don't know a value, leave it out completely.
- For ANY list of students with SGPA or marks, ALWAYS use a markdown table. Never use numbered lists (1. 2. 3.) for student rankings.
- NEVER show mathematical formulas, LaTeX notation, or calculation steps. No \frac{}, no \text{}, no \left(, no square bracket equations. Just show the final number. BAD: '[ \text{Pass Rate} = \left( \frac{16}{30} \right) \times 100 ]'. GOOD: 'The pass rate is 53.33%.'
- NEVER count rows manually from visible data. The SQL query already computed the correct number. If SQL returns a count or percentage, use THAT number exactly. Do not recount or estimate from a sample.

FOR STATISTICS AND PERCENTAGES:
- Lead with the answer: "The pass rate is X%"
- Add context in parentheses: "(Y out of Z students)"
- One sentence of insight if relevant
- End with a follow-up suggestion
- BAD: "Based on the data, I can calculate... [formula]... So approximately 53%"
- GOOD: "The overall pass rate is 53.33% (2,648 out of 4,967 students). CSE has the highest at 61.2%."

FOLLOW-UP QUERIES:
When the user asks a follow-up ("what about semester 3", "show bottom 5"), refer to conversation history. Use the same format. NEVER say "I don't have context" if history shows what was discussed.

ALWAYS END WITH:
One follow-up question suggestion.

ADDITIONAL RULES:
- End every answer with: Confidence: High/Medium/Low based on how much data supported your answer.
- If SQL returns 0 rows, say: No matching records found for [state the filters used].
- Quote exact numbers from the provided data. Never estimate or round unless the data itself is rounded."""


# ── Data model ────────────────────────────────────────────────────────────────

@dataclass
class RAGResult:
    """Result from the RAG pipeline."""
    success: bool
    chunks: list[dict] = field(default_factory=list)
    chunk_count: int = 0
    context_text: str = ""
    response: str = ""
    error: str = ""


# ── Pipeline ──────────────────────────────────────────────────────────────────

class RAGPipeline:
    """
    RAG pipeline with optional HyDE + multi-query + re-ranking + compression.

    When use_optimizations=True (default):
      HyDE → multi-query → multi-retrieve → RRF merge → re-rank → compress → generate

    When use_optimizations=False:
      embed → single retrieve → generate  (Phase 4 basic path)
    """

    def __init__(self, llm: OllamaClient, milvus: MilvusSearchClient) -> None:
        self.llm = llm
        self.milvus = milvus
        self.hyde = HyDEGenerator(llm)
        self.multi_query = MultiQueryExpander(llm)
        self.reranker = ChunkReranker()
        self.compressor = ContextualCompressor(llm)

    # ── Public interface ──────────────────────────────────────────────────────

    async def run(
        self,
        query: str,
        route_result: RouteResult,
        chat_history: list[dict] | None = None,
        use_optimizations: bool | None = None,
    ) -> RAGResult:
        """
        Full RAG pipeline: retrieve relevant chunks and generate a response.

        Args:
            query: User's natural language question
            route_result: RouteResult from router (filters, entities, intent)
            chat_history: Optional conversation history
            use_optimizations: Override the global RAG_USE_OPTIMIZATIONS setting
        """
        if use_optimizations is None:
            use_optimizations = settings.RAG_USE_OPTIMIZATIONS

        try:
            if use_optimizations:
                return await self._run_optimized(query, route_result, chat_history)
            else:
                return await self._run_basic(query, route_result, chat_history)
        except Exception as exc:
            logger.error("RAG pipeline error: %s", exc, exc_info=True)
            return RAGResult(success=False, error=f"RAG pipeline error: {exc}")

    async def retrieve_only(
        self,
        query: str,
        route_result: RouteResult,
        use_optimizations: bool | None = None,
    ) -> list[dict]:
        """
        Retrieve and refine chunks without generating a response.
        Used by HYBRID route — same full optimization chain applies.
        """
        if use_optimizations is None:
            use_optimizations = settings.RAG_USE_OPTIMIZATIONS

        filters = self._extract_filters(route_result)
        k = self._k_for_filters(route_result)

        if not use_optimizations:
            embedding = await self.llm.embed(query)
            return self.milvus.hybrid_search(
                query, embedding, k=k, filters=filters
            )

        # Optimized: HyDE + multi-query + RRF + re-rank + compress
        hyde_task = asyncio.create_task(self.hyde.generate_and_embed(query))
        expand_task = asyncio.create_task(self.multi_query.expand(query))
        (_, hyde_embedding), variants = await asyncio.gather(hyde_task, expand_task)

        all_queries = [query] + variants
        all_embeddings = [hyde_embedding]
        if variants:
            all_embeddings.extend(await self.llm.embed_batch(variants))

        all_results = []
        for q_text, q_emb in zip(all_queries, all_embeddings):
            results = self.milvus.hybrid_search(q_text, q_emb, k=20, filters=filters)
            all_results.append(results)

        merged = MultiQueryExpander.reciprocal_rank_fusion(all_results)
        reranked = self.reranker.rerank(query, merged[:30])
        compressed = await self.compressor.compress(query, reranked)
        return compressed

    # ── Pipeline paths ────────────────────────────────────────────────────────

    async def _run_optimized(
        self,
        query: str,
        route_result: RouteResult,
        chat_history: list[dict] | None,
    ) -> RAGResult:
        """
        Optimized path: HyDE + multi-query (parallel) → retrieve × N
        → RRF merge → re-rank → compress → generate.
        """
        filters = self._extract_filters(route_result)

        # Step 1: HyDE and multi-query expansion in parallel
        hyde_task = asyncio.create_task(self.hyde.generate_and_embed(query))
        expand_task = asyncio.create_task(self.multi_query.expand(query))
        (_, hyde_embedding), variants = await asyncio.gather(hyde_task, expand_task)

        # Step 2: Embed all variants (HyDE embedding replaces the original query embedding)
        all_queries = [query] + variants
        all_embeddings = [hyde_embedding]
        if variants:
            variant_embeddings = await self.llm.embed_batch(variants)
            all_embeddings.extend(variant_embeddings)

        # Step 3: Milvus hybrid search for each query variant (k=20 per variant)
        all_results: list[list[dict]] = []
        for q_text, q_emb in zip(all_queries, all_embeddings):
            results = self.milvus.hybrid_search(q_text, q_emb, k=20, filters=filters)
            all_results.append(results)

        # Step 4: Merge via RRF
        merged = MultiQueryExpander.reciprocal_rank_fusion(all_results)
        candidates = merged[:30]

        if not candidates:
            return RAGResult(
                success=True,
                chunks=[],
                chunk_count=0,
                response="I couldn't find any relevant student data for your query. Could you rephrase or provide more details?",
            )

        # Step 5: Cross-encoder re-ranking (30 → top 10)
        reranked = self.reranker.rerank(query, candidates)

        # Step 6: Contextual compression
        compressed = await self.compressor.compress(query, reranked)

        # Step 7: Assemble context and generate
        context_text = self._assemble_context(compressed, chat_history)
        response = await self._generate_response(query, context_text, chat_history)

        return RAGResult(
            success=True,
            chunks=compressed,
            chunk_count=len(compressed),
            context_text=context_text,
            response=response,
        )

    async def _run_basic(
        self,
        query: str,
        route_result: RouteResult,
        chat_history: list[dict] | None,
    ) -> RAGResult:
        """Basic path (Phase 4 logic) — single query, no re-rank/compress."""
        filters = self._extract_filters(route_result)
        k = self._k_for_filters(route_result)
        query_embedding = await self.llm.embed(query)
        chunks = self.milvus.hybrid_search(
            query, query_embedding, k=k, filters=filters
        )

        if not chunks:
            return RAGResult(
                success=True,
                chunks=[],
                chunk_count=0,
                response="I couldn't find any relevant student data for your query. Could you rephrase or provide more details?",
            )

        context_text = self._assemble_context(chunks, chat_history)
        response = await self._generate_response(query, context_text, chat_history)
        return RAGResult(
            success=True,
            chunks=chunks,
            chunk_count=len(chunks),
            context_text=context_text,
            response=response,
        )

    # ── Internal helpers ──────────────────────────────────────────────────────

    def _extract_filters(self, route_result: RouteResult) -> dict | None:
        if not route_result.needs_filter or not route_result.filters:
            return None
        filters = {}
        for key in ("semester", "branch", "roll_no", "name", "course"):
            val = route_result.filters.get(key)
            if val is not None:
                filters[key] = val

        # When querying a specific student by name or roll_no, drop the
        # semester filter so we retrieve ALL their semesters.
        if filters.get("name") or filters.get("roll_no"):
            filters.pop("semester", None)

        return filters or None

    def _k_for_filters(self, route_result: RouteResult) -> int:
        """Return a higher k when fetching a specific student's full profile."""
        f = route_result.filters or {}
        if f.get("name") or f.get("roll_no"):
            return 30  # Enough to cover all semesters + subjects
        return settings.RAG_TOP_K

    def _assemble_context(
        self,
        chunks: list[dict],
        chat_history: list[dict] | None = None,
    ) -> str:
        """
        Assemble retrieved (and optionally compressed) chunks into LLM context.

        Format per chunk:
            [N] Student: NAME | Roll: ROLL | Branch: BRANCH | Sem: SEM | SGPA: SGPA
            <chunk text (max 500 chars)>

        Max 15 chunks; individual chunks truncated to 500 chars.
        """
        display_chunks = chunks[:15]
        header = f"RETRIEVED STUDENT DATA ({len(display_chunks)} records):\n"
        parts = [header]

        for i, chunk in enumerate(display_chunks, 1):
            meta = chunk.get("metadata", {})
            meta_line = (
                f"[{i}] Student: {meta.get('name', 'N/A')} | "
                f"Roll: {meta.get('roll_no', 'N/A')} | "
                f"Branch: {meta.get('branch', 'N/A')} | "
                f"Sem: {meta.get('semester', 'N/A')} | "
                f"SGPA: {meta.get('sgpa', 'N/A')}"
            )
            text = chunk.get("text", "")
            if len(text) > 500:
                text = text[:497] + "..."
            parts.append(f"\n{meta_line}\n{text}\n")

        return "".join(parts)

    async def _get_response_prompt(self) -> str:
        """Load response generator prompt from prompts.db, fallback to hardcoded."""
        try:
            from db.sqlite_client import fetch_one
            row = await fetch_one(
                settings.PROMPTS_DB,
                "SELECT content FROM prompt_templates "
                "WHERE prompt_name = ? AND section_name = ? AND is_active = 1",
                ("response_generator", "system"),
            )
            if row and row.get("content"):
                return row["content"]
        except Exception as exc:
            logger.warning("Could not load response_generator prompt from DB: %s", exc)
        return RESPONSE_GENERATOR_PROMPT

    async def _generate_response(
        self,
        query: str,
        context_text: str,
        chat_history: list[dict] | None = None,
    ) -> str:
        """Generate response using LLM with retrieved (compressed) context."""
        system_prompt = await self._get_response_prompt()
        user_message = (
            f"Based on the following student data, answer the user's question.\n\n"
            f"{context_text}\n\n"
            f"Question: {query}"
        )

        if chat_history:
            messages = [{"role": "system", "content": system_prompt}]
            for msg in chat_history[-6:]:
                messages.append({"role": msg["role"], "content": msg["content"]})
            messages.append({"role": "user", "content": user_message})
            return await self.llm.chat(messages)
        else:
            return await self.llm.generate(
                prompt=user_message,
                system=system_prompt,
                max_tokens=settings.LLM_MAX_TOKENS,
                temperature=0.25,
                options={"temperature": 0.25},
            )
